#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cin >> s;

    if (s.length() != 6) {
        cout << "No" << endl;
        return 0;
    }

    // Проверяем первый символ — буква A-Z
    if (s[0] < 'A' || s[0] > 'Z') {
        cout << "No" << endl;
        return 0;
    }

    cout << "Yes" << endl;
    return 0;
}

