#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;

    vector<long long> snow(n + 1, 0); // Массив для снега, индексация с 1
    
    //Здесь будет обработка запросов
    for (int q = 0; q < k; ++q) {
        int type;
        cin >> type;
        
        if (type == 1) {
            int i;
            long long x;
            cin >> i >> x;
            // Сохраняем данные о снеге на улице i
            snow[i] += x; // Накапливаем количество снега
        } else if (type == 2) {
            int u, r;
            cin >> u >> r;

            long long sum = 0;
            for (int street = u; street <= r; ++street) {
                sum += snow[street];
            }
            cout << sum << endl;
        }
    }

    return 0;
}
