#include <iostream>
#include <vector>
using namespace std;

int main() {
    int h, w;
    cin >> h >> w;

    vector<vector<int>> matrix(h, vector<int>(w));

    // Считываем матрицу
    for (int i = 0; i < h; ++i) {
        for (int j = 0; j < w; ++j) {
            cin >> matrix[i][j];
        }
    }

    // Инициализируем переменные для поиска границ фигуры
    int min_row_1 = h, max_row_1 = -1;
    int min_col_1 = w, max_col_1 = -1;

    // Проходим по матрице и находим крайние координаты единиц
    for (int i = 0; i < h; ++i) {
        for (int j = 0; j < w; ++j) {
            if (matrix[i][j] == 1) {
                if (i < min_row_1) min_row_1 = i;
                if (i > max_row_1) max_row_1 = i;
                if (j < min_col_1) min_col_1 = j;
                if (j > max_col_1) max_col_1 = j;
            }
        }
    }
    // Вычисляем координаты ограничивающего прямоугольника (строго вокруг фигуры)
    int top_left_row = min_row_1 - 1;
    int top_left_col = min_col_1 - 1;
    int bottom_right_row = max_row_1 + 1;
    int bottom_right_col = max_col_1 + 1;

    // Выводим результат: верхний левый и нижний правый углы
    cout << top_left_row << " " << top_left_col << " " 
         << bottom_right_row << " " << bottom_right_col << endl;

    return 0;
}
