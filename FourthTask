#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
using namespace std;

int main() {
    int n;
    long long k;
    cin >> n >> k;
    
    // Создаём вектор для перестановки размера n
    vector<int> p(n);
    // Считываем перестановку
    for (int i = 0; i < n; i++) {
        cin >> p[i];
        p[i]--; 
    }
    
    // Считываем зашифрованное слово
    string crypt;
    cin >> crypt;
    
    // Находим циклы перестановки
    vector<bool> visit(n, false); // массив посещённых элементов
    vector<vector<int>> cycles; // вектор для хранения всех циклов
    
    for (int i = 0; i < n; i++) {
        if (!visit[i]) {
            vector<int> cycle;
            int cur = i;
            while (!visit[cur]) {
                visit[cur] = true;
                cycle.push_back(cur);
                cur = p[cur];
            }
            cycles.push_back(cycle);
        }
    }
    
    // Восстанавливаем исходное слово
    string origin(n, ' ');
    
    for (const auto& cycle : cycles) {
        int len = cycle.size();
        long long s = k % len;
       
        for (int i = 0; i < len; i++) {
            int pos = cycle[i];
            int from = cycle[(i + s) % len];
            origin[from] = crypt[pos];
        }
    }
    
    cout << origin << endl;
    
    return 0;
}
