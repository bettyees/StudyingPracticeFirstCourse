#include <iostream>
#include <vector>
using namespace std;

void dfs(int node, vector<bool>& visited, const vector<vector<int>>& graph) {
    visited[node] = true;
    // Обходим всех соседей текущего узла
    for (int neighbor : graph[node]) {
        if (!visited[neighbor]) {
            dfs(neighbor, visited, graph);
        }
    }
}

int countComponents(int n, const vector<vector<int>>& graph) {
    vector<bool> visited(n, false);
    int components = 0;

    // Перебираем все узлы
    for (int i = 0; i < n; ++i) {
        if (!visited[i]) {
            ++components;
            dfs(i, visited, graph); // Запускаем DFS для новой компоненты
        }
    }
    return components;
}

int main() {
    int n, m;
    cin >> n >> m;

    vector<pair<int, int>> edges; // Здесь будем хранить рёбра
    for (int i = 0; i < m; ++i) {
        int u, v;
        cin >> u >> v;
        edges.emplace_back(u, v);
    }
    
    // Создаём список смежности (переводим в 0‑индексацию)
    vector<vector<int>> graph(n);
    for (const auto& edge : edges) {
        int u = edge.first - 1;
        int v = edge.second - 1;
        graph[u].push_back(v);
        graph[v].push_back(u);
    }

    int k = countComponents(n, graph);
    int result = k - 1; // Для объединения k компонент нужно k-1 рёбер
    cout << result << endl;

    return 0;
}
